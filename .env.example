# Google Sheets API Configuration
# Sigue las instrucciones en GOOGLE_SHEETS_SETUP.md para obtener estos valores

# Email de la Service Account (del archivo JSON descargado)
GOOGLE_SERVICE_ACCOUNT_EMAIL="tu-service-account@tu-proyecto.iam.gserviceaccount.com"

# Private Key de la Service Account (del archivo JSON, mantén los \n)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"

# ID de tu hoja de Google Sheets (de la URL)
GOOGLE_SHEET_ID="1A2B3C4D5E6F7G8H9I0J"

# Nombre de la pestaña en tu hoja de Google Sheets
GOOGLE_SHEET_NAME="Confirmaciones"
